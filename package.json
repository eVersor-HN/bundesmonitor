{
  "name": "bundesmonitor",
  "private": true,
  "version": "0.1.0",
  "description": "Quellenbasierter, chronologischer Monitor fuer Handlungen, Planungen und Geldfluesse des Bundes.",
  "workspaces": [
    "apps/web",
    "packages/contracts",
    "packages/ui"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace apps/web",
    "build:web": "npm run build --workspace apps/web",
    "lint:web": "npm run lint --workspace apps/web",
    "typecheck:web": "npm run typecheck --workspace apps/web",
    "cap:add": "cap add android",
    "cap:sync": "cap sync android"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/local-notifications": "^8.2.0"
  }
}
