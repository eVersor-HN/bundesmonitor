# Core
APP_ENV=development
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000
DATABASE_URL=postgresql+psycopg://bundesmonitor:bundesmonitor@localhost:5432/bundesmonitor
REDIS_URL=redis://localhost:6379/0

# Object storage
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=bundesmonitor
S3_SECRET_KEY=change-me
S3_BUCKET=bundesmonitor-raw
S3_REGION=eu-central-1

# Official source credentials
DIP_API_KEY=
DIP_BASE_URL=https://search.dip.bundestag.de/api/v1
LOBBYREGISTER_API_KEY=

# Fetcher identity
SOURCE_USER_AGENT=Bundesmonitor/0.1 (+https://example.invalid/contact)
SOURCE_CONTACT_EMAIL=

# Optional AI - disabled by default
AI_SUMMARIZATION_ENABLED=false
AI_PROVIDER=
AI_API_KEY=
AI_MODEL=

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=
